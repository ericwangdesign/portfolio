---
import { publicJournalEntries } from "../../data/journal";

export function getStaticPaths() {
  return publicJournalEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{entry.title} — Journal — Eric Wang Design</title>
    <meta name="description" content={entry.excerpt} />
    <link rel="icon" type="image/png" href="/favicon-lightbg.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Spectral:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body style={`--accent:${entry.accent}; --paper:${entry.paper};`}>
    <main>
      <nav>
        <a href="/journal/">Back to canvas</a>
        <a href="/">Eric Wang Design</a>
      </nav>

      <article>
        <header class="entry-cover">
          <div class="cover-meta">
            <span>{entry.category}</span>
            <span>
              {new Date(`${entry.date}T00:00:00`).toLocaleDateString("en-US", {
                month: "long",
                day: "numeric",
                year: "numeric",
              })}
            </span>
          </div>
          <h1>{entry.title}</h1>
          <p>{entry.excerpt}</p>
        </header>

        <div class="entry-grid">
          <section class="prose">
            {entry.body.map((paragraph) => <p>{paragraph}</p>)}
          </section>

          {
            entry.notes && (
              <aside aria-label="Process notes">
                <p class="aside-title">Process notes</p>
                {entry.notes.map((note) => (
                  <p>{note}</p>
                ))}
              </aside>
            )
          }
        </div>
      </article>
    </main>

    <style is:global>
      :root {
        --ink: #17120d;
        --muted: #6c6258;
        --serif: "Spectral", Georgia, "Times New Roman", serif;
        --sans: "General Sans", "Inter", system-ui, sans-serif;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        min-height: 100svh;
        color: var(--ink);
        background:
          radial-gradient(circle at 12% 8%, color-mix(in srgb, var(--accent), transparent 78%), transparent 32%),
          linear-gradient(135deg, #f4ead6, #d6bf92);
        font-family: var(--serif);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      main {
        width: min(1120px, calc(100% - 40px));
        margin: 0 auto;
        padding: 28px 0 80px;
      }

      nav {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 64px;
        font-family: var(--sans);
        font-size: 13px;
        font-weight: 500;
      }

      nav a {
        color: inherit;
        text-decoration: none;
      }

      nav a:hover { opacity: 0.62; }

      article {
        display: flex;
        flex-direction: column;
        gap: 56px;
      }

      .entry-cover {
        position: relative;
        width: min(760px, 100%);
        min-height: 440px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 36px;
        background:
          linear-gradient(135deg, rgba(255,255,255,0.78), rgba(255,255,255,0) 48%),
          var(--paper);
        border: 1px solid rgba(23, 18, 13, 0.12);
        border-radius: 8px;
        box-shadow: 0 28px 60px rgba(61, 42, 20, 0.24);
      }

      .entry-cover::after {
        content: "";
        position: absolute;
        top: 22px;
        right: 26px;
        width: 18px;
        height: 18px;
        border-radius: 999px;
        background: var(--accent);
        box-shadow: 0 2px 8px rgba(23, 18, 13, 0.28);
      }

      .cover-meta {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        padding-right: 28px;
        font-family: var(--sans);
        font-size: 13px;
        font-weight: 600;
        color: var(--muted);
      }

      h1 {
        width: min(620px, 100%);
        margin: 44px 0 0;
        font-size: clamp(48px, 8vw, 96px);
        font-weight: 300;
        line-height: 0.92;
      }

      .entry-cover > p {
        width: min(540px, 100%);
        margin: 0;
        font-size: 21px;
        line-height: 1.3;
      }

      .entry-grid {
        display: grid;
        grid-template-columns: minmax(0, 680px) 280px;
        gap: 80px;
        align-items: start;
      }

      .prose {
        padding-left: 36px;
        border-left: 3px solid var(--accent);
      }

      .prose p {
        margin: 0 0 28px;
        font-size: 25px;
        line-height: 1.45;
      }

      aside {
        position: sticky;
        top: 28px;
        padding: 20px;
        background: rgba(255, 248, 232, 0.5);
        border: 1px solid rgba(23, 18, 13, 0.13);
        border-radius: 8px;
        font-family: var(--sans);
        font-size: 13px;
        line-height: 1.45;
        backdrop-filter: blur(12px);
      }

      aside p { margin: 0 0 12px; }
      aside p:last-child { margin-bottom: 0; }

      .aside-title {
        font-weight: 600;
        text-transform: uppercase;
        color: var(--muted);
      }

      @media (max-width: 820px) {
        main {
          width: min(100% - 36px, 1120px);
          padding-bottom: 48px;
        }

        nav {
          margin-bottom: 36px;
          font-size: 12px;
        }

        .entry-cover {
          min-height: 380px;
          padding: 24px;
        }

        .cover-meta {
          flex-direction: column;
          gap: 6px;
        }

        .entry-cover > p { font-size: 18px; }

        .entry-grid {
          grid-template-columns: 1fr;
          gap: 28px;
        }

        .prose {
          padding-left: 18px;
        }

        .prose p {
          font-size: 20px;
        }

        aside { position: static; }
      }
    </style>
  </body>
</html>
